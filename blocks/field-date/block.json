{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "gfb/field-date",
    "version": "2.0.0",
    "title": "Datum",
    "category": "gfb-fields",
    "icon": {
        "src": "calendar"
    },
    "description": "Datumsauswahl.",
    "textdomain": "gutenberg-formbuilder",
    "attributes": {
        "label": {
            "type": "string",
            "default": "Datum"
        },
        "name": {
            "type": "string",
            "default": ""
        },
        "required": {
            "type": "boolean",
            "default": false
        },
        "min": {
            "type": "string",
            "default": ""
        },
        "max": {
            "type": "string",
            "default": ""
        },
        "sensitive": {
            "type": "boolean",
            "default": false
        }
    },
    "supports": {
        "html": false,
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "text": true,
            "background": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "fontWeight": true
        },
        "border": true
    },
    "usesContext": [
        "gfb/formId",
        "gfb/appearanceMode",
        "gfb/colorLabel",
        "gfb/colorText",
        "gfb/colorPlaceholder",
        "gfb/colorFieldBg",
        "gfb/colorBorder",
        "gfb/colorFocus",
        "gfb/colorButtonBg",
        "gfb/colorButtonText",
        "gfb/darkColorLabel",
        "gfb/darkColorText",
        "gfb/darkColorPlaceholder",
        "gfb/darkColorFieldBg",
        "gfb/darkColorBorder",
        "gfb/darkColorFocus",
        "gfb/darkColorButtonBg",
        "gfb/darkColorButtonText",
        "gfb/colorFormShell",
        "gfb/darkColorFormShell"
    ],
    "editorScript": "gfb-editor",
    "example": {
        "attributes": {
            "label": "Datum",
            "name": "sb_date",
            "required": false
        }
    },
    "ancestor": [
        "gfb/form"
    ]
}
