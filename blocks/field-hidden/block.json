{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-hidden",
  "version": "0.2.1",
  "title": "Verstecktes Feld",
  "category": "gfb-fields",
  "icon": {
    "src": "editor-code"
  },
  "description": "Technischer Wert (nicht sichtbar).",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": {
      "type": "string",
      "default": ""
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "hiddenValue": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontWeight": true
    },
    "border": true
  },
  "usesContext": [
    "gfb/formId",
    "gfb/appearanceMode",
    "gfb/colorLabel",
    "gfb/colorText",
    "gfb/colorPlaceholder",
    "gfb/colorFieldBg",
    "gfb/colorBorder",
    "gfb/colorFocus",
    "gfb/colorButtonBg",
    "gfb/colorButtonText",
    "gfb/darkColorLabel",
    "gfb/darkColorText",
    "gfb/darkColorPlaceholder",
    "gfb/darkColorFieldBg",
    "gfb/darkColorBorder",
    "gfb/darkColorFocus",
    "gfb/darkColorButtonBg",
    "gfb/darkColorButtonText",
    "gfb/colorFormShell",
    "gfb/darkColorFormShell"
  ],
  "editorScript": "gfb-editor",
  "example": {
    "attributes": {
      "name": "sb_hidden",
      "hiddenValue": "stylebook"
    }
  },
  "ancestor": [
    "gfb/form"
  ]
}
