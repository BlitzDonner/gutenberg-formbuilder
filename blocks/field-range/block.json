{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-range",
  "version": "0.2.2",
  "title": "Schieberegler",
  "ancestor": ["gfb/form"],
  "category": "widgets",
  "icon": "image-flip-horizontal",
  "description": "Bereich (Slider).",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": { "type": "string", "default": "Wert" },
    "name": { "type": "string", "default": "" },
    "required": { "type": "boolean", "default": false },
    "min": { "type": "string", "default": "0" },
    "max": { "type": "string", "default": "100" },
    "step": { "type": "string", "default": "1" },
    "defaultValue": { "type": "string", "default": "" }
  },
  "supports": { "html": false },
  "usesContext": [
    "gfb/formId",
    "gfb/appearanceMode",
    "gfb/colorLabel",
    "gfb/colorText",
    "gfb/colorPlaceholder",
    "gfb/colorFieldBg",
    "gfb/colorBorder",
    "gfb/colorFocus",
    "gfb/colorButtonBg",
    "gfb/colorButtonText",
    "gfb/darkColorLabel",
    "gfb/darkColorText",
    "gfb/darkColorPlaceholder",
    "gfb/darkColorFieldBg",
    "gfb/darkColorBorder",
    "gfb/darkColorFocus",
    "gfb/darkColorButtonBg",
    "gfb/darkColorButtonText"
  ],
  "editorScript": "gfb-editor"
}
