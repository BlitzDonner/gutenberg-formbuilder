{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-select",
  "version": "0.1.0",
  "title": "Auswahlfeld",
  "ancestor": ["gfb/form"],
  "category": "widgets",
  "icon": "list-view",
  "description": "Dropdown-Auswahlfeld.",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": {
      "type": "string",
      "default": "Auswahl"
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "options": {
      "type": "string",
      "default": "Option 1\nOption 2"
    },
    "required": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false
  },
  "usesContext": [
    "gfb/formId",
    "gfb/appearanceMode",
    "gfb/colorLabel",
    "gfb/colorText",
    "gfb/colorPlaceholder",
    "gfb/colorFieldBg",
    "gfb/colorBorder",
    "gfb/colorFocus",
    "gfb/colorButtonBg",
    "gfb/colorButtonText",
    "gfb/darkColorLabel",
    "gfb/darkColorText",
    "gfb/darkColorPlaceholder",
    "gfb/darkColorFieldBg",
    "gfb/darkColorBorder",
    "gfb/darkColorFocus",
    "gfb/darkColorButtonBg",
    "gfb/darkColorButtonText"
  ],
  "editorScript": "gfb-editor"
}
