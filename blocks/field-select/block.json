{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "gfb/field-select",
    "version": "2.0.0",
    "title": "Auswahlfeld",
    "category": "gfb-fields",
    "icon": {
        "src": "list-view"
    },
    "description": "Dropdown-Auswahlfeld.",
    "textdomain": "gutenberg-formbuilder",
    "attributes": {
        "label": {
            "type": "string",
            "default": "Auswahl"
        },
        "name": {
            "type": "string",
            "default": ""
        },
        "nameClientId": {
            "type": "string",
            "default": ""
        },
        "options": {
            "type": "string",
            "default": "Option 1\nOption 2"
        },
        "required": {
            "type": "boolean",
            "default": false
        },
        "sensitive": {
            "type": "boolean",
            "default": false
        }
    },
    "supports": {
        "html": false
    },
    "usesContext": [
        "gfb/formId",
        "gfb/appearanceMode",
        "gfb/colorLabel",
        "gfb/colorText",
        "gfb/colorPlaceholder",
        "gfb/colorFieldBg",
        "gfb/colorBorder",
        "gfb/colorFocus",
        "gfb/colorButtonBg",
        "gfb/colorButtonText",
        "gfb/darkColorLabel",
        "gfb/darkColorText",
        "gfb/darkColorPlaceholder",
        "gfb/darkColorFieldBg",
        "gfb/darkColorBorder",
        "gfb/darkColorFocus",
        "gfb/darkColorButtonBg",
        "gfb/darkColorButtonText",
        "gfb/colorFormShell",
        "gfb/darkColorFormShell"
    ],
    "editorScript": "gfb-editor",
    "example": {
        "attributes": {
            "label": "Auswahl",
            "name": "sb_select",
            "options": "Option A\nOption B\nOption C",
            "required": false
        }
    },
    "ancestor": [
        "gfb/form"
    ]
}
