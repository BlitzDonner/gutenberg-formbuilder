{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "gfb/field-submit",
    "version": "2.0.0",
    "title": "Absenden-Button",
    "category": "gfb-fields",
    "icon": {
        "src": "button"
    },
    "description": "Button zum Absenden des Formulars.",
    "textdomain": "gutenberg-formbuilder",
    "attributes": {
        "label": {
            "type": "string",
            "default": "Formular absenden"
        },
        "colorFocus": {
            "type": "string",
            "default": ""
        },
        "colorButtonBg": {
            "type": "string",
            "default": ""
        },
        "colorButtonText": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false
    },
    "usesContext": [
        "gfb/formId",
        "gfb/appearanceMode",
        "gfb/colorLabel",
        "gfb/colorText",
        "gfb/colorPlaceholder",
        "gfb/colorFieldBg",
        "gfb/colorBorder",
        "gfb/colorFocus",
        "gfb/colorButtonBg",
        "gfb/colorButtonText",
        "gfb/darkColorLabel",
        "gfb/darkColorText",
        "gfb/darkColorPlaceholder",
        "gfb/darkColorFieldBg",
        "gfb/darkColorBorder",
        "gfb/darkColorFocus",
        "gfb/darkColorButtonBg",
        "gfb/darkColorButtonText",
        "gfb/colorFormShell",
        "gfb/darkColorFormShell"
    ],
    "editorScript": "gfb-editor",
    "example": {
        "attributes": {
            "label": "Absenden"
        }
    },
    "ancestor": [
        "gfb/form"
    ]
}
