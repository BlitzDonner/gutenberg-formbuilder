{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-tel",
  "version": "0.2.0",
  "title": "Telefon",
  "category": "gfb-fields",
  "icon": {
    "src": "phone",
    "foreground": "#1b2627"
  },
  "description": "Telefonnummer.",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": {
      "type": "string",
      "default": "Telefon"
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "required": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontWeight": true
    },
    "border": true
  },
  "usesContext": [
    "gfb/formId",
    "gfb/appearanceMode",
    "gfb/colorLabel",
    "gfb/colorText",
    "gfb/colorPlaceholder",
    "gfb/colorFieldBg",
    "gfb/colorBorder",
    "gfb/colorFocus",
    "gfb/colorButtonBg",
    "gfb/colorButtonText",
    "gfb/darkColorLabel",
    "gfb/darkColorText",
    "gfb/darkColorPlaceholder",
    "gfb/darkColorFieldBg",
    "gfb/darkColorBorder",
    "gfb/darkColorFocus",
    "gfb/darkColorButtonBg",
    "gfb/darkColorButtonText",
    "gfb/colorFormShell",
    "gfb/darkColorFormShell"
  ],
  "editorScript": "gfb-editor",
  "example": {
    "attributes": {
      "label": "Telefon",
      "name": "sb_tel",
      "placeholder": "+41 …",
      "required": false
    }
  },
  "ancestor": [
    "gfb/form"
  ]
}
