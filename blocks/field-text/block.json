{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-text",
  "version": "0.1.0",
  "title": "Textfeld",
  "ancestor": ["gfb/form"],
  "category": "widgets",
  "icon": "editor-textcolor",
  "description": "Einzeiliges Textfeld.",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": {
      "type": "string",
      "default": "Textfeld"
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "required": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false
  },
  "usesContext": [
    "gfb/formId"
  ],
  "editorScript": "gfb-editor",
  "editorStyle": "file:../../assets/gfb-editor.css"
}
