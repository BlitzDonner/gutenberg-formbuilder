{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/field-textarea",
  "version": "0.1.0",
  "title": "Textbereich",
  "ancestor": ["gfb/form"],
  "category": "widgets",
  "icon": "editor-paragraph",
  "description": "Mehrzeiliges Texteingabefeld.",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "label": {
      "type": "string",
      "default": "Nachricht"
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "required": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false
  },
  "usesContext": [
    "gfb/formId"
  ],
  "editorScript": "gfb-editor",
  "editorStyle": "file:../../assets/gfb-editor.css"
}
