{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gfb/form",
  "version": "1.0.0-beta.3",
  "title": "Formular",
  "category": "gfb-form",
  "icon": {
    "src": "feedback"
  },
  "description": "Formular-Container für den seitenbasierten Formbuilder.",
  "textdomain": "gutenberg-formbuilder",
  "attributes": {
    "formId": {
      "type": "string"
    },
    "blockInstanceId": {
      "type": "string"
    },
    "draftEnabled": {
      "type": "boolean",
      "default": true
    },
    "draftTtlDays": {
      "type": "number",
      "default": 7
    },
    "restoreMode": {
      "type": "string",
      "default": "prompt"
    },
    "showDraftReset": {
      "type": "boolean",
      "default": true
    },
    "thankYouPageId": {
      "type": "number",
      "default": 0
    },
    "appearanceMode": {
      "type": "string",
      "default": "theme"
    },
    "colorLabel": { "type": "string", "default": "" },
    "colorText": { "type": "string", "default": "" },
    "colorPlaceholder": { "type": "string", "default": "" },
    "colorFieldBg": { "type": "string", "default": "" },
    "colorBorder": { "type": "string", "default": "" },
    "colorFocus": { "type": "string", "default": "" },
    "colorButtonBg": { "type": "string", "default": "" },
    "colorButtonText": { "type": "string", "default": "" },
    "colorFormShell": { "type": "string", "default": "" },
    "darkColorLabel": { "type": "string", "default": "" },
    "darkColorText": { "type": "string", "default": "" },
    "darkColorPlaceholder": { "type": "string", "default": "" },
    "darkColorFieldBg": { "type": "string", "default": "" },
    "darkColorBorder": { "type": "string", "default": "" },
    "darkColorFocus": { "type": "string", "default": "" },
    "darkColorButtonBg": { "type": "string", "default": "" },
    "darkColorButtonText": { "type": "string", "default": "" },
    "darkColorFormShell": { "type": "string", "default": "" }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "layout": {
      "allowEditing": false,
      "allowInheriting": false,
      "default": {
        "type": "flex",
        "orientation": "vertical"
      }
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "border": true
  },
  "providesContext": {
    "gfb/formId": "formId",
    "gfb/appearanceMode": "appearanceMode",
    "gfb/colorLabel": "colorLabel",
    "gfb/colorText": "colorText",
    "gfb/colorPlaceholder": "colorPlaceholder",
    "gfb/colorFieldBg": "colorFieldBg",
    "gfb/colorBorder": "colorBorder",
    "gfb/colorFocus": "colorFocus",
    "gfb/colorButtonBg": "colorButtonBg",
    "gfb/colorButtonText": "colorButtonText",
    "gfb/colorFormShell": "colorFormShell",
    "gfb/darkColorLabel": "darkColorLabel",
    "gfb/darkColorText": "darkColorText",
    "gfb/darkColorPlaceholder": "darkColorPlaceholder",
    "gfb/darkColorFieldBg": "darkColorFieldBg",
    "gfb/darkColorBorder": "darkColorBorder",
    "gfb/darkColorFocus": "darkColorFocus",
    "gfb/darkColorButtonBg": "darkColorButtonBg",
    "gfb/darkColorButtonText": "darkColorButtonText",
    "gfb/darkColorFormShell": "darkColorFormShell"
  },
  "editorScript": "gfb-editor"
}
