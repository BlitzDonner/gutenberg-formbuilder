msgid "Update-Server nicht erreichbar."
msgstr "Server di aggiornamento non raggiungibile."

msgid "Der Server konnte gerade nicht erreicht werden. Das ist meist vorübergehend – später erneut «Token testen»."
msgstr "Al momento non è stato possibile raggiungere il server. Di solito è temporaneo – riprova più tardi con «Prova token»."

msgid "Kein Token hinterlegt."
msgstr "Nessun token salvato."

msgid "Trage unten ein Lizenz-Token ein, um automatische Updates zu aktivieren. Ohne Token läuft das Plugin normal weiter."
msgstr "Inserisci sotto un token di licenza per attivare gli aggiornamenti automatici. Senza token il plugin continua a funzionare normalmente."

msgid "Lizenz-Token wird per wp-config gesetzt (Vorrang). Eingaben im Backend werden ignoriert."
msgstr "Il token di licenza è impostato tramite wp-config (precedenza). Le voci nel backend vengono ignorate."

msgid "Update-Client nicht verfügbar."
msgstr "Client di aggiornamento non disponibile."

msgid "Lizenz-Token gespeichert."
msgstr "Token di licenza salvato."

msgid "Token testen: Token gültig – automatische Updates aktiv."
msgstr "Prova token: token valido – aggiornamenti automatici attivi."

msgid "Token testen: Token per wp-config gesetzt (Vorrang)."
msgstr "Prova token: token impostato tramite wp-config (precedenza)."

msgid "Token testen: Token abgelaufen oder ungültig – keine Updates."
msgstr "Prova token: token scaduto o non valido – nessun aggiornamento."

msgid "Token testen: Update-Server nicht erreichbar – bitte später erneut versuchen."
msgstr "Prova token: server di aggiornamento non raggiungibile – riprova più tardi."

